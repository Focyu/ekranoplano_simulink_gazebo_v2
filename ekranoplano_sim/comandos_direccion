source /opt/ros/humble/setup.bash 

# Sube a 1.5 metros
ros2 topic pub /setpoint/altura std_msgs/msg/Float64 "{data: 1.5}" -1

# Inclina la nariz ligeramente hacia arriba (~2 grados)
ros2 topic pub /setpoint/pitch std_msgs/msg/Float64 "{data: 0.0349}" -1

# Inicia un giro a la derecha de 20 grados
ros2 topic pub /setpoint/yaw std_msgs/msg/Float64 "{data: 0.349}" -1

# Endereza la nave
ros2 topic pub /setpoint/yaw std_msgs/msg/Float64 "{data: 0.0}" -1
